#pragma once

// project name version
#define @PROJECT_NAME_UP@_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define @PROJECT_NAME_UP@_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define @PROJECT_NAME_UP@_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define @PROJECT_NAME_UP@_VERSION ((PROJECT_VERSION_MAJOR * 1000) + PROJECT_VERSION_MINOR) * 1000 + PROJECT_VERSION_PATCH

#define @PROJECT_NAME_UP@_VERSION_STRING "@PROJECT_VERSION@"

// build system
#define @PROJECT_NAME_UP@_BUILD_SYSTEM "@LC_KMCMAKE_PRETTY_NAME@"

// build system version
#define @PROJECT_NAME_UP@_BUILD_SYSTEM_VERSION "@KMCMAKE_DISTRO_VERSION_ID@"


// compiler gnu or clang
#define @PROJECT_NAME_UP@_CXX_COMPILER_ID "@CMAKE_CXX_COMPILER_ID@"

// compiler version
#define @PROJECT_NAME_UP@_CXX_COMPILER_VERSION "@CMAKE_CXX_COMPILER_VERSION@"

// cmake cxx compiler flags
#define @PROJECT_NAME_UP@_CMAKE_CXX_COMPILER_FLAGS "@CMAKE_CXX_COMPILER_FLAGS@"

// user defined cxx compiler flags
#define @PROJECT_NAME_UP@_CXX_COMPILER_FLAGS "@KMCMAKE_CXX_OPTIONS@"

// cxx standard
#define @PROJECT_NAME_UP@_CXX_STANDARD "@CMAKE_CXX_STANDARD@"

// build type
#define @PROJECT_NAME_UP@_BUILD_TYPE_STRING "@UPPERCASE_BUILD_TYPE@"

// build type
#define @PROJECT_NAME_UP@_BUILD_@UPPERCASE_BUILD_TYPE@

// build type
#if defined(@PROJECT_NAME_UP@_BUILD_DEBUG)
    #define IS_@PROJECT_NAME_UP@_BUILD_TYPE_DEBUG 1
#else
    #define IS_@PROJECT_NAME_UP@_BUILD_TYPE_DEBUG 0
#endif

////////////////////////////////////////////////////////////////////////////////
/// simd region

#define KMCMAKE_SIMD_LEVEL_NONE @KMCMAKE_SIMD_LEVEL_NONE_VAL@
#define KMCMAKE_SIMD_LEVEL_SSE @KMCMAKE_SIMD_LEVEL_SSE_VAL@
#define KMCMAKE_SIMD_LEVEL_AVX @KMCMAKE_SIMD_LEVEL_AVX_VAL@
#define KMCMAKE_SIMD_LEVEL_AVX2 @KMCMAKE_SIMD_LEVEL_AVX2_VAL@
#define KMCMAKE_SIMD_LEVEL_BMI @KMCMAKE_SIMD_LEVEL_BMI_VAL@
#define KMCMAKE_SIMD_LEVEL_BMI2 @KMCMAKE_SIMD_LEVEL_BMI2_VAL@
#define KMCMAKE_SIMD_LEVEL_FMA @KMCMAKE_SIMD_LEVEL_FMA_VAL@
#define KMCMAKE_SIMD_LEVEL_MOVBE @KMCMAKE_SIMD_LEVEL_MOVBE_VAL@

///////////////////////////////////////////////////////////////////////////////////
/// git and version region

////////////////////////////////////////////////////////////////////////////////
/// Git Version Information
////////////////////////////////////////////////////////////////////////////////
// Full Git commit hash (e.g., "a1b2c3d4e5f67890abcdef1234567890abcdef12")
#define @PROJECT_NAME_UP@_GIT_COMMIT_HASH "@GIT_COMMIT_HASH@"
// Short Git commit hash (e.g., "a1b2c3d")
#define @PROJECT_NAME_UP@_GIT_COMMIT_SHORT_HASH "@GIT_COMMIT_SHORT_HASH@"
// Git dirty flag (0 = clean working tree, 1 = uncommitted changes)
#define @PROJECT_NAME_UP@_GIT_IS_DIRTY @GIT_IS_DIRTY@
// Combined Git version string (e.g., "0.6.0-a1b2c3d" or "0.6.0-a1b2c3d-dirty")
#define @PROJECT_NAME_UP@_GIT_VERSION_STRING "@GIT_VERSION_STRING@"